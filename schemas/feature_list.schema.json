{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://adds.dev/schemas/feature_list.schema.json",
  "title": "ADDS Feature List Schema",
  "description": "Schema for validating feature_list.md structure in ADDS projects",
  "type": "object",
  "required": ["features"],
  "properties": {
    "features": {
      "type": "array",
      "description": "List of features in the project",
      "items": {
        "$ref": "#/definitions/feature"
      }
    }
  },
  "definitions": {
    "feature": {
      "type": "object",
      "required": ["id", "title", "category", "priority", "status"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^F[0-9]{3}$",
          "description": "Feature identifier (e.g., F001, F042)"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Short feature description"
        },
        "category": {
          "type": "string",
          "enum": ["core", "feature", "fix", "refactor", "chore", "test", "docs"],
          "description": "Feature category"
        },
        "priority": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "Development priority"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "testing", "completed", "blocked", "regression"],
          "description": "Current development status"
        },
        "dependencies": {
          "type": "array",
          "description": "List of feature IDs this feature depends on",
          "items": {
            "type": "string",
            "pattern": "^F[0-9]{3}$"
          }
        },
        "complexity": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Estimated implementation complexity"
        },
        "steps": {
          "type": "array",
          "description": "Implementation steps",
          "items": {
            "type": "string"
          }
        },
        "test_cases": {
          "type": "array",
          "description": "Test cases for this feature",
          "items": {
            "$ref": "#/definitions/testCase"
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "description": "Acceptance criteria checklist",
          "items": {
            "type": "string"
          }
        },
        "security_checks": {
          "type": "array",
          "description": "Security considerations",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "testCase": {
      "type": "object",
      "required": ["id", "description", "type"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^T[0-9]{3}-[0-9]{2}$",
          "description": "Test case identifier (e.g., T001-01)"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["unit", "integration", "e2e"]
        },
        "status": {
          "type": "string",
          "enum": ["pending", "passed", "failed", "skipped"]
        }
      }
    }
  }
}
